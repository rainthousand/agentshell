{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentshell.local/schemas/plugin-status.schema.json",
  "title": "AgentShell Plugin Status Response",
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["ok", "protocolVersion", "checkedAt", "plugin", "paths", "summary", "checks", "suggestedNextActions"],
      "properties": {
        "ok": { "type": "boolean" },
        "protocolVersion": { "enum": ["agentshell.plugin-status.v1", "agentshell.plugin-doctor-local.v1"] },
        "checkedAt": { "type": "string" },
        "plugin": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "version", "authorName", "developerName"],
          "properties": {
            "name": { "type": ["string", "null"] },
            "version": { "type": ["string", "null"] },
            "authorName": { "type": ["string", "null"] },
            "developerName": { "type": ["string", "null"] }
          }
        },
        "paths": {
          "type": "object",
          "additionalProperties": false,
          "required": ["root", "manifest", "marketplace", "cacheRoot"],
          "properties": {
            "root": { "type": "string" },
            "manifest": { "type": "string" },
            "marketplace": { "type": "string" },
            "cacheRoot": { "type": "string" },
            "cachePath": { "type": "string" },
            "cacheManifest": { "type": "string" }
          }
        },
        "summary": {
          "type": "object",
          "additionalProperties": false,
          "required": ["total", "passed", "failed", "warnings"],
          "properties": {
            "total": { "type": "integer", "minimum": 0 },
            "passed": { "type": "integer", "minimum": 0 },
            "failed": { "type": "integer", "minimum": 0 },
            "warnings": { "type": "integer", "minimum": 0 }
          }
        },
        "checks": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["name", "ok", "severity"],
            "properties": {
              "name": { "type": "string" },
              "ok": { "type": "boolean" },
              "severity": { "enum": ["error", "warning"] },
              "suggestedNextActions": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "suggestedNextActions": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["ok", "protocolVersion", "compact", "checkedAt", "status", "plugin", "summary", "cachePath", "nextAction", "suggestedNextActions"],
      "properties": {
        "ok": { "type": "boolean" },
        "protocolVersion": { "enum": ["agentshell.plugin-status.v1", "agentshell.plugin-doctor-local.v1"] },
        "compact": { "const": true },
        "checkedAt": { "type": "string" },
        "status": { "enum": ["ready", "warning", "blocked"] },
        "plugin": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "version", "authorName", "developerName"],
          "properties": {
            "name": { "type": ["string", "null"] },
            "version": { "type": ["string", "null"] },
            "authorName": { "type": ["string", "null"] },
            "developerName": { "type": ["string", "null"] }
          }
        },
        "summary": {
          "type": "object",
          "additionalProperties": false,
          "required": ["total", "passed", "failed", "warnings"],
          "properties": {
            "total": { "type": "integer", "minimum": 0 },
            "passed": { "type": "integer", "minimum": 0 },
            "failed": { "type": "integer", "minimum": 0 },
            "warnings": { "type": "integer", "minimum": 0 }
          }
        },
        "cachePath": { "type": ["string", "null"] },
        "nextAction": {
          "oneOf": [
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["command", "reason", "text"],
              "properties": {
                "command": { "type": ["string", "null"] },
                "reason": { "type": "string" },
                "text": { "type": "string" }
              }
            },
            { "type": "null" }
          ]
        },
        "suggestedNextActions": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    { "$ref": "common.schema.json#/$defs/failure" }
  ]
}
