{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentshell.local/schemas/adapter-trial.schema.json",
  "title": "AgentShell Adapter Trial Report",
  "type": "object",
  "required": [
    "ok",
    "protocolVersion",
    "generatedAt",
    "host",
    "fixture",
    "score",
    "interpretation",
    "criteria",
    "metrics",
    "commands",
    "finalVerification",
    "notes"
  ],
  "properties": {
    "ok": { "type": "boolean" },
    "protocolVersion": { "const": "agentshell.adapter-trial.v1" },
    "generatedAt": { "type": "string" },
    "host": { "enum": ["codex", "claude", "cursor", "windsurf", "agents-md", "other"] },
    "fixture": { "type": ["string", "null"] },
    "score": { "type": "integer", "minimum": 0, "maximum": 100 },
    "interpretation": { "enum": ["strong", "usable", "weak"] },
    "criteria": {
      "type": "object",
      "required": ["firstTwoCommands", "fastRepairPath", "compactContext", "verification", "safety", "noiseControl"],
      "properties": {
        "firstTwoCommands": { "$ref": "#/$defs/criterion" },
        "fastRepairPath": { "$ref": "#/$defs/criterion" },
        "compactContext": { "$ref": "#/$defs/criterion" },
        "verification": { "$ref": "#/$defs/criterion" },
        "safety": { "$ref": "#/$defs/criterion" },
        "noiseControl": { "$ref": "#/$defs/criterion" }
      },
      "additionalProperties": false
    },
    "metrics": { "$ref": "#/$defs/metrics" },
    "commands": {
      "type": "array",
      "items": { "$ref": "#/$defs/command" }
    },
    "finalVerification": {
      "anyOf": [
        { "$ref": "#/$defs/finalVerification" },
        { "type": "null" }
      ]
    },
    "notes": { "type": ["string", "null"] }
  },
  "additionalProperties": false,
  "$defs": {
    "criterion": {
      "type": "object",
      "required": ["points", "max", "ok", "reason"],
      "properties": {
        "points": { "type": "integer", "minimum": 0 },
        "max": { "type": "integer", "minimum": 0 },
        "ok": { "type": "boolean" },
        "reason": { "type": "string" }
      },
      "additionalProperties": false
    },
    "metrics": {
      "type": "object",
      "required": [
        "commandCount",
        "agentShellCommandCount",
        "noisyRawCommandCount",
        "firstAgentShellCommandIndex",
        "firstNoisyRawCommandIndex",
        "totalOutputTokens",
        "totalDurationMs",
        "averageOutputTokensPerCommand",
        "averageDurationMsPerCommand"
      ],
      "properties": {
        "commandCount": { "type": "integer", "minimum": 0 },
        "agentShellCommandCount": { "type": "integer", "minimum": 0 },
        "noisyRawCommandCount": { "type": "integer", "minimum": 0 },
        "firstAgentShellCommandIndex": { "type": ["integer", "null"], "minimum": 0 },
        "firstNoisyRawCommandIndex": { "type": ["integer", "null"], "minimum": 0 },
        "totalOutputTokens": { "type": "integer", "minimum": 0 },
        "totalDurationMs": { "type": "integer", "minimum": 0 },
        "averageOutputTokensPerCommand": { "type": "integer", "minimum": 0 },
        "averageDurationMsPerCommand": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "command": {
      "type": "object",
      "required": ["command", "outputTokens", "durationMs"],
      "properties": {
        "command": { "type": "string" },
        "outputTokens": { "type": "integer", "minimum": 0 },
        "durationMs": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "finalVerification": {
      "type": "object",
      "required": ["ok", "command", "summary"],
      "properties": {
        "ok": { "type": "boolean" },
        "command": { "type": ["string", "null"] },
        "summary": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    }
  }
}
