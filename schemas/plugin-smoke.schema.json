{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentshell.local/schemas/plugin-smoke.schema.json",
  "title": "AgentShell Plugin Smoke Report",
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["ok", "protocolVersion", "installedPath", "summary", "checks"],
      "properties": {
        "ok": { "type": "boolean" },
        "protocolVersion": { "const": "agentshell.plugin-smoke.v1" },
        "installedPath": { "type": "string" },
        "summary": { "$ref": "#/$defs/summary" },
        "checks": {
          "type": "array",
          "items": { "$ref": "#/$defs/check" }
        }
      }
    },
    { "$ref": "common.schema.json#/$defs/failure" }
  ],
  "$defs": {
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total", "passed", "failed"],
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "passed": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 }
      }
    },
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "ok"],
      "properties": {
        "name": { "type": "string" },
        "ok": { "type": "boolean" },
        "error": { "type": "string" }
      }
    }
  }
}
