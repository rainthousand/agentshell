{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentshell.local/schemas/change.schema.json",
  "title": "AgentShell Change Spec",
  "type": "object",
  "required": ["edits"],
  "properties": {
    "reason": { "type": "string" },
    "dryRun": { "type": "boolean" },
    "edits": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["file", "expectedHash", "range", "replacement"],
        "properties": {
          "file": { "type": "string" },
          "expectedHash": { "type": "string", "pattern": "^sha256:" },
          "range": {
            "type": "object",
            "required": ["start", "end"],
            "properties": {
              "start": { "type": "integer", "minimum": 1 },
              "end": { "type": "integer", "minimum": 1 }
            },
            "additionalProperties": false
          },
          "replacement": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
