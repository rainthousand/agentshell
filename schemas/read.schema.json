{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentshell.local/schemas/read.schema.json",
  "title": "AgentShell Read Response",
  "oneOf": [
    {
      "type": "object",
      "required": ["ok", "protocolVersion", "file", "hash", "range", "matchedLine", "totalLines", "content"],
      "properties": {
        "ok": { "const": true },
        "protocolVersion": { "const": "agentshell.read.v1" },
        "file": { "type": "string" },
        "hash": { "type": "string", "pattern": "^sha256:" },
        "range": {
          "type": "object",
          "required": ["start", "end"],
          "properties": {
            "start": { "type": "integer", "minimum": 1 },
            "end": { "type": "integer", "minimum": 1 }
          },
          "additionalProperties": false
        },
        "matchedLine": { "type": ["integer", "null"] },
        "totalLines": { "type": "integer", "minimum": 0 },
        "content": { "type": "string" }
      },
      "additionalProperties": false
    },
    { "$ref": "common.schema.json#/$defs/failure" }
  ]
}
