{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentshell.local/schemas/change-suggest.schema.json",
  "title": "AgentShell Change Suggest Response",
  "type": "object",
  "required": ["ok", "compact", "dryRun", "runId", "template", "fill", "confidence", "strategy", "preview", "suggestedNextActions"],
  "properties": {
    "ok": { "const": true },
    "compact": { "type": "boolean" },
    "dryRun": { "type": "boolean" },
    "runId": { "type": ["string", "null"] },
    "template": { "type": "string" },
    "fill": { "type": "string" },
    "confidence": { "enum": ["none", "low", "medium", "high"] },
    "strategy": { "enum": ["missing-object-property", "deep-equal-missing-property", "deep-equal-array-elements", "deep-equal-array-removal", "deep-equal-extra-property-removal", "deep-equal-array-primitive-replacement", "array-length", "literal-replacement", "join-separator-literal", "string-case-transform", "truthy-return", "missing-named-export", "import-path", "typescript-missing-property", "typescript-primitive-literal-mismatch", "typescript-literal-mismatch", "typescript-property-suggestion", "unknown"] },
    "preview": {
      "type": "object",
      "required": ["file", "range", "fill"],
      "properties": {
        "file": { "type": "string" },
        "range": {
          "type": "object",
          "required": ["start", "end"],
          "properties": {
            "start": { "type": "integer", "minimum": 1 },
            "end": { "type": "integer", "minimum": 1 }
          },
          "additionalProperties": false
        },
        "fill": { "type": "string" }
      },
      "additionalProperties": false
    },
    "replacement": { "type": "string" },
    "applied": { "$ref": "#/$defs/appliedChange" },
    "suggestedNextActions": {
      "type": "array",
      "items": { "$ref": "common.schema.json#/$defs/suggestedNextAction" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "appliedChange": {
      "type": "object",
      "required": ["ok", "operationId", "changedFiles", "diffSummary"],
      "properties": {
        "ok": { "const": true },
        "operationId": { "type": "string" },
        "changedFiles": {
          "type": "array",
          "items": { "type": "string" }
        },
        "diffSummary": {
          "type": "object",
          "required": ["insertions", "deletions"],
          "properties": {
            "insertions": { "type": "integer", "minimum": 0 },
            "deletions": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  }
}
