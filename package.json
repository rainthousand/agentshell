{
  "name": "agentshell",
  "version": "1.0.0",
  "description": "A structured local CLI for AI coding agents.",
  "type": "module",
  "bin": {
    "agentshell": "./bin/agentshell",
    "ashell": "./bin/agentshell",
    "agentshell-mcp": "./bin/agentshell-mcp"
  },
  "scripts": {
    "test": "node --test tests/*.test.js",
    "test:mcp": "node --test tests/mcp-server.test.js",
    "demo": "cd examples/failing-test-demo && node ../../src/cli.js verify test",
    "benchmark": "node scripts/benchmark-demo.js",
    "benchmark:cache": "node scripts/cache-benchmark.js",
    "benchmark:cold-start": "node scripts/cold-start-benchmark.js",
    "benchmark:first-round": "node scripts/first-round-benchmark.js",
    "benchmark:suite": "node scripts/benchmark-suite.js",
    "benchmark:suite:ci": "node scripts/benchmark-suite.js --ci",
    "performance:summary": "node scripts/performance-summary.js",
    "dashboard": "node src/cli.js dashboard",
    "dashboard:build-app": "node scripts/build-dashboard-app.js",
    "build:standalone": "node scripts/build-standalone.js",
    "eval:real-projects": "node scripts/real-project-eval.js",
    "eval:real-project-candidates": "node scripts/real-project-candidates.js",
    "strategy:coverage": "node scripts/strategy-coverage-matrix.js",
    "strategy:intake": "node scripts/strategy-intake.js",
    "product:readiness": "node scripts/product-readiness.js",
    "product:readiness:heavy": "node scripts/product-readiness.js --heavy",
    "share:package": "node scripts/share-package.js",
    "package:lifecycle:smoke": "node scripts/package-lifecycle-smoke.js",
    "adapter:generate": "node scripts/adapter-generate.js",
    "adapter:trial": "node scripts/adapter-trial.js",
    "adapter:trial:collect": "node scripts/adapter-trial-collect.js",
    "adapter:trial:suite": "node scripts/adapter-trial-suite.js",
    "adapter:package:claude": "node scripts/adapter-generate.js --package claude",
    "adapter:package:cursor": "node scripts/adapter-generate.js --package cursor",
    "codex:e2e": "node scripts/codex-plugin-e2e.js",
    "codex:plugin:trial": "node scripts/codex-plugin-trial.js",
    "codex:plugin:collect": "node scripts/codex-plugin-trial-collect.js",
    "codex:plugin:template": "node scripts/codex-plugin-trial-template.js",
    "codex:plugin:plan": "node scripts/codex-plugin-trial-plan.js",
    "codex:plugin:suite": "node scripts/codex-plugin-trial-suite.js",
    "codex:plugin:export": "node src/cli.js trial export",
    "beta:funnel": "node scripts/beta-funnel.js",
    "plugin:validate": "node src/cli.js plugin validate --compact",
    "plugin:validate:source": "node src/cli.js plugin validate --source-only --compact",
    "plugin:smoke": "node scripts/plugin-smoke.js",
    "plugin:smoke:markdown": "node scripts/plugin-smoke.js --markdown",
    "plugin:activation-smoke": "node scripts/plugin-activation-smoke.js",
    "plugin:doctor-local": "node scripts/plugin-doctor-local.js",
    "plugin:cachebust": "python3 scripts/update-plugin-cachebuster.py .",
    "plugin:install-local": "node scripts/install-codex-plugin.js",
    "plugin:release-local": "node scripts/plugin-release-local.js",
    "install:codex": "node scripts/install-for-codex-user.js",
    "update:codex": "node scripts/install-for-codex-user.js --action update",
    "uninstall:codex": "node scripts/install-for-codex-user.js --action uninstall",
    "doctor:codex": "node scripts/plugin-lifecycle.js doctor",
    "plugin:lifecycle": "node scripts/plugin-lifecycle.js",
    "security:scan": "node scripts/security-scan.js",
    "release:gate": "node scripts/release-gate.js",
    "release:artifacts": "node scripts/release-artifacts.js",
    "v1:smoke": "node scripts/v1-clean-machine-smoke.js",
    "support:bundle": "node scripts/support-bundle.js",
    "install:agent-policy": "node scripts/install-agent-policy.js"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
